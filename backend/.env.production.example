# ============================================================
# .env.production — NUNCA commitar o arquivo real com valores
# Copie para .env no servidor e preencha com valores reais
# ============================================================

# --- Ambiente (OBRIGATÓRIO: deve ser "production") ---
NODE_ENV=production
PORT=3000

# --- Banco de dados ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=corefinance_user
DB_PASSWORD=SENHA_FORTE_AQUI
DB_NAME=corefinance

# --- JWT ---
# Gerar com: openssl rand -hex 64
JWT_SECRET=COLE_AQUI_O_SEGREDO_GERADO_COM_OPENSSL
JWT_EXPIRES_IN=8h

# --- CORS ---
# Domínio exato do frontend (sem barra no final)
# Múltiplos domínios separados por vírgula: https://app.dominio.com,https://dominio.com
CORS_ORIGIN=https://seudominio.com

# --- Redis (se utilizado) ---
REDIS_HOST=localhost
REDIS_PORT=6379
